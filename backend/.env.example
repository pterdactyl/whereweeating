# Copy to backend/.env — see README.md for full setup.

PORT=5000
# CORS allowlist. Local: http://localhost:5173. Production: https://your-domain
FRONTEND_URL=http://localhost:5173

# Required for API (auth + all DB access)
JWT_SECRET=replace-with-a-long-random-secret
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated; only these emails can perform admin-only actions
ADMIN_EMAILS=you@example.com

# Optional — only for npm run sync:restaurants and report:restaurant-dupes
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
YELP_API_KEY=your-yelp-fusion-api-key
